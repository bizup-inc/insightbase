---
import Layout from "../../layouts/Layout.astro";
import Footer from "../../components/Footer.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
---

<Layout
  title="OGPзўәиӘҚгғ„гғјгғ«пҪңURLгӮ’е…ҘеҠӣгҒ—гҒҰOGPгғ»Twitter CardгӮ’гғҒгӮ§гғғгӮҜпҪңInsightBase"
  description="URLгӮ’е…ҘеҠӣгҒҷгӮӢгҒ гҒ‘гҒ§гҖҒOGPгӮ„Twitter CardгҒ®иЁӯе®ҡзҠ¶жіҒгӮ’зўәиӘҚгҒ§гҒҚгӮӢз„Ўж–ҷгғ„гғјгғ«гҒ§гҒҷгҖӮog:titleгҖҒog:descriptionгҖҒog:image гҒӘгҒ©гҒ®metaжғ…е ұгӮ’иҰӢгӮ„гҒҷгҒҸиЎЁзӨәгҒ—гҒҫгҒҷгҖӮ"
>
  <div class="ogp-checker-page">
    <section class="ogp-checker-hero ogp-checker-fullbleed is-visible">
      <div class="content__inner ogp-checker-hero__inner">
        <div>
          <Breadcrumbs
            items={[
              { label: "TOP", href: "/" },
              { label: "з„Ўж–ҷгғ„гғјгғ«", href: "/tools/" },
              { label: "OGPзўәиӘҚгғ„гғјгғ«" },
            ]}
          />
          <div class="ogp-checker-hero__eyebrow">FREE TOOL</div>
          <h1>OGPзўәиӘҚгғ„гғјгғ«</h1>
          <p>
            OGPзўәиӘҚгғ„гғјгғ«гҒҜгҖҒе…ҘеҠӣгҒ—гҒҹURLгҒ®OGPгӮ„Twitter CardиЁӯе®ҡгӮ’еҸ–еҫ—гҒ—гҒҰиЎЁзӨәгҒҷгӮӢз„Ўж–ҷгғ„гғјгғ«гҒ§гҒҷгҖӮе…¬й–ӢгғҡгғјгӮёгҒ®metaжғ…е ұгӮ’зўәиӘҚгҒ—гҒҹгҒ„гҒЁгҒҚгӮ„гҖҒSNSгӮ·гӮ§гӮўжҷӮгҒ®иЁӯе®ҡжјҸгӮҢгӮ’гғҒгӮ§гғғгӮҜгҒ—гҒҹгҒ„гҒЁгҒҚгҒ«дҫҝеҲ©гҒ§гҒҷгҖӮ
          </p>
          <small class="ogp-checker-hero__note">
            вҖ» гҒ“гҒ®гғ„гғјгғ«гҒҜгғҡгғјгӮёеҶ…гҒ®metaжғ…е ұгӮ’еҸ–еҫ—гҒ—гҒҰиЎЁзӨәгҒҷгӮӢзўәиӘҚз”Ёгғ„гғјгғ«гҒ§гҒҷгҖӮ<br />
            вҖ» е®ҹйҡӣгҒ®SNSгӮ·гӮ§гӮўиЎЁзӨәгҒҜеҗ„гӮөгғјгғ“гӮ№гҒ®д»•ж§ҳгӮ„гӮӯгғЈгғғгӮ·гғҘгҒ«гӮҲгӮҠз•°гҒӘгӮӢе ҙеҗҲгҒҢгҒӮгӮҠгҒҫгҒҷгҖӮеҜҫиұЎгӮөгӮӨгғҲгҒ®иЁӯе®ҡгҒ«гӮҲгҒЈгҒҰгҒҜжғ…е ұгӮ’еҸ–еҫ—гҒ§гҒҚгҒӘгҒ„е ҙеҗҲгҒҢгҒӮгӮҠгҒҫгҒҷгҖӮ
          </small>
        </div>
      </div>
    </section>

    <section class="ogp-checker-section is-visible">
      <div class="content__inner ogp-checker-layout">
        <div class="ogp-checker-panel">
          <h2>URLгӮ’зўәиӘҚгҒҷгӮӢ</h2>

          <form class="ogp-checker-form" data-ogp-checker>
            <div class="ogp-checker-field">
              <label for="ogp-target-url">
                URL
                <span class="ogp-checker-required">еҝ…й Ҳ</span>
              </label>
              <input
                id="ogp-target-url"
                name="targetUrl"
                type="url"
                inputmode="url"
                placeholder="https://example.com/page"
                autocomplete="off"
              />
              <small>е…¬й–ӢжёҲгҒҝгҒ®URLгӮ’е…ҘеҠӣгҒҷгӮӢгҒЁгҖҒOGP / Twitter Cardй–ўйҖЈгҒ®metaжғ…е ұгӮ’еҸ–еҫ—гҒ—гҒҫгҒҷгҖӮ</small>
            </div>

            <div class="ogp-checker-actions">
              <button
                class="ogp-checker-button ogp-checker-button--paste"
                type="button"
                data-ogp-paste
              >
                гғҡгғјгӮ№гғҲ
              </button>
              <button class="ogp-checker-button ogp-checker-button--primary" type="submit">
                зўәиӘҚгҒҷгӮӢ
              </button>
              <button class="ogp-checker-button ogp-checker-button--ghost" type="reset">
                гӮҜгғӘгӮў
              </button>
            </div>

            <div class="ogp-checker-status" data-ogp-status></div>
            <div class="ogp-checker-loading" data-ogp-loading hidden>еҸ–еҫ—дёӯгҒ§гҒҷгҖӮж•°з§’гҒҠеҫ…гҒЎгҒҸгҒ гҒ•гҒ„гҖӮ</div>
            <div class="ogp-checker-alert ogp-checker-alert--error" data-ogp-error hidden></div>

            <section class="ogp-checker-info-section">
              <div class="ogp-checker-info-section__header">
                <h2>гҒ“гҒ®гғ„гғјгғ«гҒ§гҒ§гҒҚгӮӢгҒ“гҒЁ</h2>
              </div>
              <div class="ogp-checker-sidebar__card ogp-checker-sidebar__card--inline">
                <ul>
                  <li>URLгӮ’е…ҘеҠӣгҒҷгӮӢгҒ гҒ‘гҒ§гҖҒOGPгҒЁTwitter CardгҒ®иЁӯе®ҡзҠ¶жіҒгӮ’гҒҫгҒЁгӮҒгҒҰзўәиӘҚгҒ§гҒҚгҒҫгҒҷгҖӮ</li>
                  <li>е…¬й–ӢеҫҢгҒ®иЁӯе®ҡжјҸгӮҢгғҒгӮ§гғғгӮҜгӮ„гҖҒSNSгӮ·гӮ§гӮўз”Ёmetaжғ…е ұгҒ®иҰӢзӣҙгҒ—гҒ«дҪҝгҒҲгҒҫгҒҷгҖӮ</li>
                  <li>з”»еғҸURLгӮ„зӣёеҜҫгғ‘гӮ№гҒ®иЈңе®ҢзҠ¶жіҒгӮӮгҒӮгӮҸгҒӣгҒҰзўәиӘҚгҒ§гҒҚгҒҫгҒҷгҖӮ</li>
                </ul>
              </div>
            </section>

            <div class="ogp-checker-result" data-ogp-result hidden>
              <section class="ogp-checker-result__section">
                <div class="ogp-checker-result__header">
                  <h2>SNSеҲҘгӮӨгғЎгғјгӮёгғ—гғ¬гғ“гғҘгғј</h2>
                </div>
                <p class="ogp-checker-preview-note">
                  д»ҘдёӢгҒҜеҗ„SNSгҒ§е…ұжңүгҒ•гӮҢгҒҹгҒЁгҒҚгҒ®гӮӨгғЎгғјгӮёгҒ§гҒҷгҖӮе®ҹйҡӣгҒ®иЎЁзӨәгҒҜгӮөгғјгғ“гӮ№еҒҙгҒ®д»•ж§ҳгӮ„гӮӯгғЈгғғгӮ·гғҘзҠ¶жіҒгҒ«гӮҲгӮҠз•°гҒӘгӮӢе ҙеҗҲгҒҢгҒӮгӮҠгҒҫгҒҷгҖӮзўәиӘҚз”ЁгҒ®ж“¬дјјгғ—гғ¬гғ“гғҘгғјгҒ®гҒҹгӮҒгҖҒе®ҹйҡӣгҒ®иҰӢгҒҲж–№гҒЁгҒҜе®Ңе…ЁгҒ«гҒҜдёҖиҮҙгҒ—гҒҫгҒӣгӮ“гҖӮ
                </p>
                <div class="ogp-checker-social-previews" data-social-previews></div>
              </section>

              <section class="ogp-checker-result__section">
                <div class="ogp-checker-result__header">
                  <h2>еҹәжң¬жғ…е ұ</h2>
                  <button
                    class="ogp-checker-button ogp-checker-button--chip"
                    type="button"
                    data-copy-result
                  >
                    зөҗжһңгӮ’гӮігғ”гғј
                  </button>
                </div>
                <div class="ogp-checker-info-grid">
                  <div class="ogp-checker-info-card">
                    <strong>еҜҫиұЎURL</strong>
                    <span data-ogp-requested-url></span>
                  </div>
                  <div class="ogp-checker-info-card">
                    <strong>жңҖзөӮеҸ–еҫ—URL</strong>
                    <span data-ogp-final-url></span>
                  </div>
                  <div class="ogp-checker-info-card">
                    <strong>еҸ–еҫ—зөҗжһң</strong>
                    <span data-ogp-fetch-status></span>
                  </div>
                </div>
              </section>

              <section class="ogp-checker-result__section">
                <div class="ogp-checker-result__header">
                  <h2>з°Ўжҳ“гғҒгӮ§гғғгӮҜзөҗжһң</h2>
                </div>
                <ul class="ogp-checker-checklist" data-ogp-checks></ul>
              </section>

              <section class="ogp-checker-result__section">
                <div class="ogp-checker-result__header">
                  <h2>OGP</h2>
                </div>
                <div class="ogp-checker-meta-grid" data-ogp-list></div>
              </section>

              <section class="ogp-checker-result__section">
                <div class="ogp-checker-result__header">
                  <h2>Twitter Card</h2>
                </div>
                <div class="ogp-checker-meta-grid" data-twitter-list></div>
              </section>

              <section class="ogp-checker-result__section">
                <div class="ogp-checker-result__header">
                  <h2>иЈңеҠ©жғ…е ұ</h2>
                </div>
                <div class="ogp-checker-meta-grid" data-basic-list></div>
              </section>
            </div>
          </form>
        </div>
      </div>
    </section>

    <div class="ogp-checker-fullbleed">
      <Footer />
    </div>
  </div>
</Layout>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const form = document.querySelector("[data-ogp-checker]");
    if (!(form instanceof HTMLFormElement)) return;

    const urlField = form.elements.namedItem("targetUrl");
    const status = form.querySelector("[data-ogp-status]");
    const loading = form.querySelector("[data-ogp-loading]");
    const error = form.querySelector("[data-ogp-error]");
    const result = form.querySelector("[data-ogp-result]");
    const pasteButton = form.querySelector("[data-ogp-paste]");
    const copyButton = form.querySelector("[data-copy-result]");
    const requestedUrlOutput = form.querySelector("[data-ogp-requested-url]");
    const finalUrlOutput = form.querySelector("[data-ogp-final-url]");
    const fetchStatusOutput = form.querySelector("[data-ogp-fetch-status]");
    const checksList = form.querySelector("[data-ogp-checks]");
    const ogpList = form.querySelector("[data-ogp-list]");
    const twitterList = form.querySelector("[data-twitter-list]");
    const basicList = form.querySelector("[data-basic-list]");
    const socialPreviews = form.querySelector("[data-social-previews]");

    let copyText = "";

    const setStatus = (message, state = "") => {
      if (!(status instanceof HTMLElement)) return;
      status.textContent = message;
      status.dataset.state = state;
    };

    const showLoading = (visible) => {
      if (loading instanceof HTMLElement) {
        loading.hidden = !visible;
      }
    };

    const showError = (message) => {
      if (!(error instanceof HTMLElement)) return;
      error.hidden = false;
      error.textContent = message;
    };

    const hideError = () => {
      if (!(error instanceof HTMLElement)) return;
      error.hidden = true;
      error.textContent = "";
    };

    const setResultVisible = (visible) => {
      if (result instanceof HTMLElement) {
        result.hidden = !visible;
      }
    };

    const clearChildren = (element) => {
      if (element instanceof HTMLElement) {
        element.innerHTML = "";
      }
    };

    const createMetaCard = (label, value) => {
      const item = document.createElement("div");
      item.className = "ogp-checker-meta-card";

      const title = document.createElement("strong");
      title.textContent = label;

      const body = document.createElement("span");
      body.textContent = value || "жңӘиЁӯе®ҡгҒ§гҒҷ";
      if (!value) {
        body.className = "is-empty";
      }

      item.append(title, body);
      return item;
    };

    const truncateText = (value, maxLength) => {
      if (!value) return "";
      return value.length > maxLength ? `${value.slice(0, maxLength - 1)}вҖҰ` : value;
    };

    const escapeHtml = (value = "") =>
      value
        .replaceAll("&", "&amp;")
        .replaceAll("<", "&lt;")
        .replaceAll(">", "&gt;")
        .replaceAll('"', "&quot;")
        .replaceAll("'", "&#39;");

    const getDomainLabel = (value) => {
      if (!value) return "";
      try {
        return new URL(value).hostname.replace(/^www\./, "");
      } catch {
        return value;
      }
    };

    const renderMetaSection = (container, fields) => {
      if (!(container instanceof HTMLElement)) return;
      clearChildren(container);
      fields.forEach((field) => {
        container.append(createMetaCard(field.label, field.value));
      });
    };

    const renderChecks = (checks) => {
      if (!(checksList instanceof HTMLElement)) return;
      clearChildren(checksList);

      checks.forEach((check) => {
        const item = document.createElement("li");
        item.className = `ogp-checker-checklist__item is-${check.state}`;
        item.innerHTML = `<strong>${check.label}</strong> ${check.message}`;
        checksList.append(item);
      });
    };

    const createSocialCardMarkup = ({
      platform,
      device,
      title,
      description,
      image,
      domain,
      url,
      specLabel,
      mediaClass,
    }) => {
      const platformLabel =
        platform === "x" ? "X" : platform.charAt(0).toUpperCase() + platform.slice(1);
      const eyebrow =
        platform === "facebook"
          ? domain
          : platform === "x"
            ? `@preview вҖў ${domain}`
            : platform === "line"
              ? domain
              : "InstagramйўЁгғ—гғ¬гғ“гғҘгғј";

      const imageMarkup = image
        ? `<img class="ogp-social-card__image" src="${escapeHtml(image)}" alt="${platformLabel} preview" loading="lazy" />`
        : `<div class="ogp-social-card__placeholder">${platform === "instagram" ? "з”»еғҸгҒӘгҒ—" : "No Image"}</div>`;

      const descriptionMarkup =
        platform !== "instagram"
          ? `<p class="ogp-social-card__description">${escapeHtml(description || "иӘ¬жҳҺж–ҮгҒӘгҒ—")}</p>`
          : description
            ? `<p class="ogp-social-card__description is-instagram">${escapeHtml(description)}</p>`
            : "";

      return `
        <div class="ogp-social-preview is-${platform} is-${device}">
          <div class="ogp-social-preview__header">
            <div class="ogp-social-preview__titlegroup">
              <h3>${platformLabel}</h3>
              <small>${escapeHtml(specLabel)}</small>
            </div>
            <span>${device === "pc" ? "PCзүҲ" : "гӮ№гғһгғӣзүҲ"}</span>
          </div>
          <div class="ogp-social-card is-${platform} is-${device}">
            <div class="ogp-social-card__media ${mediaClass}">
              ${imageMarkup}
            </div>
            <div class="ogp-social-card__body">
              <div class="ogp-social-card__eyebrow">${escapeHtml(eyebrow || url)}</div>
              <h4 class="ogp-social-card__title">${escapeHtml(title || url || "гӮҝгӮӨгғҲгғ«жңӘиЁӯе®ҡ")}</h4>
              ${descriptionMarkup}
              <div class="ogp-social-card__footer">${escapeHtml(domain || url)}</div>
            </div>
          </div>
        </div>
      `;
    };

    const renderSocialPreviews = (data) => {
      if (!(socialPreviews instanceof HTMLElement)) return;
      clearChildren(socialPreviews);

      const baseTitle = data.ogp.title || data.basic.title || data.finalUrl;
      const baseDescription = data.ogp.description || data.basic.description || "";
      const baseImage = data.ogp.image || data.twitter.image || "";
      const baseDomain = getDomainLabel(data.finalUrl);

      const xTitle = data.twitter.title || data.ogp.title || data.basic.title || data.finalUrl;
      const xDescription = data.twitter.description || data.ogp.description || data.basic.description || "";
      const xImage = data.twitter.image || data.ogp.image || "";
      const xCardType = data.twitter.card || "";
      const xIsLargeImage = xCardType === "summary_large_image";

      const previewConfigs = [
        {
          platform: "facebook",
          device: "pc",
          title: truncateText(baseTitle, 72),
          description: truncateText(baseDescription, 120),
          image: baseImage,
          domain: baseDomain,
          url: data.finalUrl,
          specLabel: "1.91:1 / 1200Г—630 жҺЁеҘЁ",
          mediaClass: "is-landscape",
        },
        {
          platform: "facebook",
          device: "mobile",
          title: truncateText(baseTitle, 52),
          description: truncateText(baseDescription, 90),
          image: baseImage,
          domain: baseDomain,
          url: data.finalUrl,
          specLabel: "1.91:1 / 1200Г—630 жҺЁеҘЁ",
          mediaClass: "is-landscape",
        },
        {
          platform: "instagram",
          device: "pc",
          title: truncateText(baseTitle, 44),
          description: truncateText(baseDescription, 52),
          image: baseImage,
          domain: baseDomain,
          url: data.finalUrl,
          specLabel: "InstagramйўЁ / 1:1гғҷгғјгӮ№",
          mediaClass: "is-square",
        },
        {
          platform: "instagram",
          device: "mobile",
          title: truncateText(baseTitle, 32),
          description: truncateText(baseDescription, 36),
          image: baseImage,
          domain: baseDomain,
          url: data.finalUrl,
          specLabel: "InstagramйўЁ / 1:1гғҷгғјгӮ№",
          mediaClass: "is-square",
        },
        {
          platform: "line",
          device: "pc",
          title: truncateText(baseTitle, 58),
          description: truncateText(baseDescription, 68),
          image: baseImage,
          domain: baseDomain,
          url: data.finalUrl,
          specLabel: "LINEгҒҜ og:title / og:description / og:image гӮ’дҪҝз”Ё",
          mediaClass: "is-landscape",
        },
        {
          platform: "line",
          device: "mobile",
          title: truncateText(baseTitle, 42),
          description: truncateText(baseDescription, 52),
          image: baseImage,
          domain: baseDomain,
          url: data.finalUrl,
          specLabel: "LINEгҒҜ og:title / og:description / og:image гӮ’дҪҝз”Ё",
          mediaClass: "is-landscape",
        },
        {
          platform: "x",
          device: "pc",
          title: truncateText(xTitle, 70),
          description: truncateText(xDescription, 110),
          image: xImage,
          domain: baseDomain,
          url: data.finalUrl,
          specLabel: xIsLargeImage ? "summary_large_image / 2:1" : "summary / 1:1",
          mediaClass: xIsLargeImage ? "is-x-large" : "is-square",
        },
        {
          platform: "x",
          device: "mobile",
          title: truncateText(xTitle, 48),
          description: truncateText(xDescription, 86),
          image: xImage,
          domain: baseDomain,
          url: data.finalUrl,
          specLabel: xIsLargeImage ? "summary_large_image / 2:1" : "summary / 1:1",
          mediaClass: xIsLargeImage ? "is-x-large" : "is-square",
        },
      ];

      socialPreviews.innerHTML = previewConfigs.map((config) => createSocialCardMarkup(config)).join("");

      socialPreviews.querySelectorAll(".ogp-social-card__image").forEach((img) => {
        if (!(img instanceof HTMLImageElement)) return;

        img.addEventListener("error", () => {
          const media = img.closest(".ogp-social-card__media");
          const card = img.closest(".ogp-social-card");
          if (!(media instanceof HTMLElement) || !(card instanceof HTMLElement)) return;

          const isInstagram = card.classList.contains("is-instagram");
          media.innerHTML = `<div class="ogp-social-card__placeholder">${isInstagram ? "з”»еғҸгҒӘгҒ—" : "з”»еғҸгӮ’иЎЁзӨәгҒ§гҒҚгҒҫгҒӣгӮ“"}</div>`;
        });
      });

      if (!socialPreviews.children.length) {
        socialPreviews.innerHTML =
          '<div class="ogp-checker-preview__empty">SNSеҲҘгӮӨгғЎгғјгӮёгғ—гғ¬гғ“гғҘгғјгӮ’иЎЁзӨәгҒ§гҒҚгҒҫгҒӣгӮ“гҒ§гҒ—гҒҹгҖӮ</div>';
      }
    };

    const buildCopyText = (data) => {
      const lines = [
        `еҜҫиұЎURL: ${data.requestedUrl}`,
        `жңҖзөӮеҸ–еҫ—URL: ${data.finalUrl}`,
        `еҸ–еҫ—зөҗжһң: еҸ–еҫ—жҲҗеҠҹ`,
        "",
        "[OGP]",
        `og:title: ${data.ogp.title || "жңӘиЁӯе®ҡгҒ§гҒҷ"}`,
        `og:description: ${data.ogp.description || "жңӘиЁӯе®ҡгҒ§гҒҷ"}`,
        `og:image: ${data.ogp.image || "жңӘиЁӯе®ҡгҒ§гҒҷ"}`,
        `og:url: ${data.ogp.url || "жңӘиЁӯе®ҡгҒ§гҒҷ"}`,
        `og:type: ${data.ogp.type || "жңӘиЁӯе®ҡгҒ§гҒҷ"}`,
        `og:site_name: ${data.ogp.siteName || "жңӘиЁӯе®ҡгҒ§гҒҷ"}`,
        `og:locale: ${data.ogp.locale || "жңӘиЁӯе®ҡгҒ§гҒҷ"}`,
        "",
        "[Twitter Card]",
        `twitter:card: ${data.twitter.card || "жңӘиЁӯе®ҡгҒ§гҒҷ"}`,
        `twitter:title: ${data.twitter.title || "жңӘиЁӯе®ҡгҒ§гҒҷ"}`,
        `twitter:description: ${data.twitter.description || "жңӘиЁӯе®ҡгҒ§гҒҷ"}`,
        `twitter:image: ${data.twitter.image || "жңӘиЁӯе®ҡгҒ§гҒҷ"}`,
        `twitter:site: ${data.twitter.site || "жңӘиЁӯе®ҡгҒ§гҒҷ"}`,
        "",
        "[иЈңеҠ©жғ…е ұ]",
        `title: ${data.basic.title || "жңӘиЁӯе®ҡгҒ§гҒҷ"}`,
        `meta description: ${data.basic.description || "жңӘиЁӯе®ҡгҒ§гҒҷ"}`,
        "",
        "[з°Ўжҳ“гғҒгӮ§гғғгӮҜзөҗжһң]",
        ...data.checks.map((check) => `${check.label}: ${check.message}`),
      ];

      return lines.join("\n");
    };

    const resetResult = () => {
      setResultVisible(false);
      hideError();
      showLoading(false);
      copyText = "";
      if (requestedUrlOutput instanceof HTMLElement) requestedUrlOutput.textContent = "";
      if (finalUrlOutput instanceof HTMLElement) finalUrlOutput.textContent = "";
      if (fetchStatusOutput instanceof HTMLElement) fetchStatusOutput.textContent = "";
      clearChildren(checksList);
      clearChildren(ogpList);
      clearChildren(twitterList);
      clearChildren(basicList);
      clearChildren(socialPreviews);
    };

    form.addEventListener("submit", async (event) => {
      event.preventDefault();
      hideError();

      if (!(urlField instanceof HTMLInputElement)) return;
      const targetUrl = urlField.value.trim();

      if (!targetUrl) {
        resetResult();
        showError("URLгӮ’е…ҘеҠӣгҒ—гҒҰгҒҸгҒ гҒ•гҒ„гҖӮ");
        setStatus("е…ҘеҠӣеҶ…е®№гӮ’зўәиӘҚгҒ—гҒҰгҒҸгҒ гҒ•гҒ„гҖӮ", "error");
        return;
      }

      try {
        const parsed = new URL(targetUrl);
        if (!["http:", "https:"].includes(parsed.protocol)) {
          throw new Error("invalid protocol");
        }
      } catch {
        resetResult();
        showError("URLгҒ®еҪўејҸгҒҢжӯЈгҒ—гҒҸгҒӮгӮҠгҒҫгҒӣгӮ“гҖӮ`https://` гҒҫгҒҹгҒҜ `http://` гҒӢгӮүе§ӢгҒҫгӮӢURLгӮ’е…ҘеҠӣгҒ—гҒҰгҒҸгҒ гҒ•гҒ„гҖӮ");
        setStatus("е…ҘеҠӣеҶ…е®№гӮ’зўәиӘҚгҒ—гҒҰгҒҸгҒ гҒ•гҒ„гҖӮ", "error");
        return;
      }

      showLoading(true);
      setResultVisible(false);
      setStatus("URLгҒ®metaжғ…е ұгӮ’еҸ–еҫ—гҒ—гҒҰгҒ„гҒҫгҒҷгҖӮ", "");

      try {
        const response = await fetch("/api/ogp-check", {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
          },
          body: JSON.stringify({ url: targetUrl }),
        });

        const payload = await response.json();
        if (!response.ok || !payload.success) {
          throw new Error(payload.error || "жғ…е ұгӮ’еҸ–еҫ—гҒ§гҒҚгҒҫгҒӣгӮ“гҒ§гҒ—гҒҹгҖӮ");
        }

        const { data } = payload;

        if (requestedUrlOutput instanceof HTMLElement) requestedUrlOutput.textContent = data.requestedUrl;
        if (finalUrlOutput instanceof HTMLElement) finalUrlOutput.textContent = data.finalUrl;
        if (fetchStatusOutput instanceof HTMLElement) fetchStatusOutput.textContent = "еҸ–еҫ—жҲҗеҠҹ";

        renderChecks(data.checks);
        renderMetaSection(ogpList, [
          { label: "og:title", value: data.ogp.title },
          { label: "og:description", value: data.ogp.description },
          { label: "og:image", value: data.ogp.image },
          { label: "og:url", value: data.ogp.url },
          { label: "og:type", value: data.ogp.type },
          { label: "og:site_name", value: data.ogp.siteName },
          { label: "og:locale", value: data.ogp.locale },
        ]);
        renderMetaSection(twitterList, [
          { label: "twitter:card", value: data.twitter.card },
          { label: "twitter:title", value: data.twitter.title },
          { label: "twitter:description", value: data.twitter.description },
          { label: "twitter:image", value: data.twitter.image },
          { label: "twitter:site", value: data.twitter.site },
        ]);
        renderMetaSection(basicList, [
          { label: "title", value: data.basic.title },
          { label: 'meta name="description"', value: data.basic.description },
        ]);
        renderSocialPreviews(data);

        copyText = buildCopyText(data);
        setResultVisible(true);
        setStatus("OGP / Twitter Card гҒ®иЁӯе®ҡзҠ¶жіҒгӮ’еҸ–еҫ—гҒ—гҒҫгҒ—гҒҹгҖӮ", "success");
      } catch (requestError) {
        resetResult();
        showError(
          requestError instanceof Error
            ? requestError.message
            : "еҜҫиұЎгӮөгӮӨгғҲгҒ®иЁӯе®ҡгҒ«гӮҲгӮҠеҸ–еҫ—гҒ§гҒҚгҒӘгҒ„е ҙеҗҲгҒҢгҒӮгӮҠгҒҫгҒҷгҖӮ"
        );
        setStatus("еҸ–еҫ—гҒ«еӨұж•—гҒ—гҒҫгҒ—гҒҹгҖӮ", "error");
      } finally {
        showLoading(false);
      }
    });

    form.addEventListener("reset", () => {
      window.setTimeout(() => {
        resetResult();
        setStatus("е…ҘеҠӣеҶ…е®№гӮ’гӮҜгғӘгӮўгҒ—гҒҫгҒ—гҒҹгҖӮ", "warning");
      }, 0);
    });

    if (pasteButton instanceof HTMLButtonElement && urlField instanceof HTMLInputElement) {
      pasteButton.addEventListener("click", async () => {
        try {
          const pastedText = await navigator.clipboard.readText();
          if (!pastedText) {
            setStatus("гӮҜгғӘгғғгғ—гғңгғјгғүгҒ«гғҶгӮӯгӮ№гғҲгҒҢиҰӢгҒӨгҒӢгӮҠгҒҫгҒӣгӮ“гҒ§гҒ—гҒҹгҖӮ", "warning");
            return;
          }

          urlField.value = pastedText;
          urlField.focus();
          setStatus("гӮҜгғӘгғғгғ—гғңгғјгғүгҒ®URLгӮ’иІјгӮҠд»ҳгҒ‘гҒҫгҒ—гҒҹгҖӮгҖҢзўәиӘҚгҒҷгӮӢгҖҚгӮ’жҠјгҒ—гҒҰеҸ–еҫ—гҒ—гҒҰгҒҸгҒ гҒ•гҒ„гҖӮ", "success");
        } catch {
          setStatus("гғҡгғјгӮ№гғҲгҒ«еӨұж•—гҒ—гҒҫгҒ—гҒҹгҖӮгғ–гғ©гӮҰгӮ¶гҒ®иЁұеҸҜиЁӯе®ҡгӮ’зўәиӘҚгҒ—гҒҰгҒҸгҒ гҒ•гҒ„гҖӮ", "error");
        }
      });
    }

    if (copyButton instanceof HTMLButtonElement) {
      copyButton.addEventListener("click", async () => {
        if (!copyText) {
          setStatus("е…ҲгҒ«зөҗжһңгӮ’еҸ–еҫ—гҒ—гҒҰгҒҸгҒ гҒ•гҒ„гҖӮ", "warning");
          return;
        }

        try {
          await navigator.clipboard.writeText(copyText);
          setStatus("зўәиӘҚзөҗжһңгӮ’гӮігғ”гғјгҒ—гҒҫгҒ—гҒҹгҖӮ", "success");
        } catch {
          setStatus("гӮігғ”гғјгҒ«еӨұж•—гҒ—гҒҫгҒ—гҒҹгҖӮжүӢеӢ•гҒ§еҶ…е®№гӮ’гӮігғ”гғјгҒ—гҒҰгҒҸгҒ гҒ•гҒ„гҖӮ", "error");
        }
      });
    }

    setStatus("URLгӮ’е…ҘеҠӣгҒ—гҒҰгҖҢзўәиӘҚгҒҷгӮӢгҖҚгӮ’жҠјгҒҷгҒЁгҖҒOGPгҒЁTwitter CardгҒ®иЁӯе®ҡзҠ¶жіҒгӮ’зўәиӘҚгҒ§гҒҚгҒҫгҒҷгҖӮ", "");
  });
</script>
