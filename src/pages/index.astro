---
import Layout from "../layouts/Layout.astro";
import Hero from "../components/Hero.astro";
import Work from "../components/Work.astro";
import Custom from "../components/Custom.astro";
import Cta from "../components/Cta.astro";
import Footer from "../components/Footer.astro";

const customerVoices = [
  {
    text:
      "これまでは管理画面から数字を拾ってレポートにまとめるだけで多くの時間がかかっていました。InsightBaseを導入してからは、月初の作業負担が大きく減り、本来の業務に時間を使えるようになりました。",
    image: "/assets/img/voice/img01.jpg",
    alt: "マーケティング担当者のアイコン",
    role: "Web担当者",
    meta: "サービス業 / K.Kさま",
  },
  {
    text:
      "見やすく整理されたデザインなので、クライアント提出用として使いやすいと感じました。数字を並べるだけではなく、全体の傾向が伝わりやすい点も良かったです。",
    image: "/assets/img/voice/img02.jpg",
    alt: "フリーランスマーケターのアイコン",
    role: "フリーランス",
    meta: "Webマーケター / A.Iさま",
  },
  {
    text:
      "自分で一から作ろうとすると、項目設計や見せ方で手が止まりがちでした。テンプレートがあることで、必要な形を短時間で整えられたのが助かりました。",
    image: "/assets/img/voice/img03.jpg",
    alt: "事業責任者のアイコン",
    role: "ディレクター",
    meta: "製作会社 / T.Yさま",
  },
  {
    text:
      "クライアントから数値について質問を受けた際も、以前より説明しやすくなりました。必要な指標が整理されているので、報告や共有がスムーズになったと感じています。",
    image: "/assets/img/voice/img04.jpg",
    alt: "マーケティングのアイコン",
    role: "マーケティング担当",
    meta: "支援会社 / S.Nさま",
  },
  {
    text:
      "GA4の数字を整理して確認しやすくなりました。必要な指標が見やすくまとまっているので、毎週の社内向けレポート提出が楽になりました。",
    image: "/assets/img/voice/img05.jpg",
    alt: "マーケティング責任者のアイコン",
    role: "Web担当者",
    meta: "事業会社 / H.Kさま",
  },
  {
    text:
      "使っていくうちにLooker Studioの仕様や考え方がわかるようになり、今では自分仕様のレポートも作成できるようになりました。単に使うだけでなく、学びながら活用できる点も良かったです。",
    image: "/assets/img/voice/img06.jpg",
    alt: "Web担当者",
    role: "Web担当者",
    meta: "製作会社 / R.Oさま",
  },
];

const customerVoiceSlides = [
  customerVoices.slice(0, 3),
  customerVoices.slice(3, 6),
];

// Welcome to Astro! Wondering what to do next? Check out the Astro documentation at https://docs.astro.build
// Don't want to use any of this? Delete everything in this file, the `assets`, `components`, and `layouts` directories, and start fresh.
---

<Layout
  title="完全買切り Looker Studioテンプレート｜GA4・Google広告対応｜InsightBase"
>
  <Hero
    hasBg={true}
    title={`<span>毎月のレポート作成を仕組み化。</span><br>GA4・広告レポート自動作成`}
    image="/assets/img/hero/hero-image.svg"
    ctaText="今すぐ購入する"
    ctaLink="#cta"
    description="GA4・Google広告のアカウントを接続するだけでプロ仕様のレポートが即完成。"
  />
</Layout>

<section class="section__bg_w">
  <div class="content__inner">
    <div class="solution">
      <img src="/assets/img/logo/ib_logo.svg" alt="InsightBase Logo" />
      <h2 class="section__title">レポート作成の課題、解決します。</h2>
      <p>
        InsightBaseは、レポート作成の「非効率」を仕組みで解決する、Looker
        Studio用のテンプレートです。<br />
        InsightBaseを導入することで、以下のような課題を即座に解決し、レポート作成に奪われていた時間を改善提案の時間へと変えます。
      </p>
    </div>
    <div class="lead__features --pt20">
      <div class="lead__feature">
        <img
          src="/assets/img/nayami01.svg"
          alt="レポート作成の課題01「レポート作成に時間がとられすぎ」"
        />
        <h3>レポート作成に時間がとられすぎ</h3>
        <p>レポート作成にかなりの時間がかかり、本来の業務に手が回らない。</p>
      </div>

      <div class="lead__feature">
        <img
          src="/assets/img/nayami02.svg"
          alt="レポート作成の課題02「数字だけのレポートでは刺さらない」"
        />
        <h3>数字だけのレポートでは刺さらない</h3>
        <p>
          せっかくまとめた集計データも、数字の羅列だけでクライアントの反応が薄い。
        </p>
      </div>

      <div class="lead__feature">
        <img
          src="/assets/img/nayami03.svg"
          alt="レポート作成の課題03「レポートの体裁を整えるのが大変」"
        />
        <h3>レポートの体裁を整えるのが大変</h3>
        <p>レイアウト調整に時間がかかり、中身より見た目に労力を使っている。</p>
      </div>

      <div class="lead__feature">
        <img
          src="/assets/img/nayami04.svg"
          alt="レポート作成の課題04「案件ごとにフォーマットがバラバラ」"
        />
        <h3>案件ごとにフォーマットがバラバラ</h3>
        <p>クライアントごとに形式が違い、毎回ゼロから作り直している。</p>
      </div>
    </div>
  </div>
</section>

<section class="section__bg_w report-fit">
  <div class="content__inner">
    <div class="report-fit__label">こんな方におすすめ！</div>
    <div class="report-fit__panel">
      <ol class="report-fit__list">
        <li class="report-fit__item">
          <span class="report-fit__number">1</span>
          <p>GA4や広告レポートを毎回手作業でまとめている</p>
        </li>
        <li class="report-fit__item">
          <span class="report-fit__number">2</span>
          <p>Looker Studioでレポートを作りたいが、作り方がわからない</p>
        </li>
        <li class="report-fit__item">
          <span class="report-fit__number">3</span>
          <p>クライアント提出用のレポート作成に時間がかかっている</p>
        </li>
        <li class="report-fit__item">
          <span class="report-fit__number">4</span>
          <p>数字は取れているのに、どこを見れば良いかわからない</p>
        </li>
        <li class="report-fit__item">
          <span class="report-fit__number">5</span>
          <p>見やすく整ったレポートをすぐに使える形で導入したい</p>
        </li>
      </ol>
    </div>
  </div>
</section>

<section class="section__bg_lgreen">
  <div class="content__inner">
    <p class="section__title_en">High Time Performance</p>
    <h2 class="section__title">タイパ重視のプロ仕様レポート</h2>
    <div class="lead__text">
      <p>
        GA4・Google広告のGoogleアカウントを接続するだけで、今まで何時間もかかっていたレポートが即完成。<br
        />
        完成したレポートはPDFデータ、共有リンク、メール配信でクライアント様と共有が可能。
      </p>

      <p class="notice">
        ※ 共有機能はLooker Studioの基本機能に搭載されています。
      </p>
    </div>

    <Work />
  </div>
</section>

<section class="section__bg_w">
  <div class="content__inner">
    <p class="section__title_en">High Cost Performance</p>
    <h2 class="section__title">完全買切り。ずっと使える。</h2>
    <div class="lead__text">
      <p>
        本テンプレートは、Google Looker Studio（無料）で利用可能。<br />
        一度導入すれば追加費用不要で、すべてのクライアント様に活用できます。
      </p>
    </div>

    <div class="lead__features3 --pt20">
      <div class="lead__feature">
        <img src="/assets/img/point.svg" alt="完全買切り" />
        <h3>完全買切り</h3>
        <p class="text-center">
          初期費用や月額費用は一切不要。 費用はテンプレート購入費用のみ。
        </p>
      </div>

      <div class="lead__feature3">
        <img src="/assets/img/point.svg" alt="追加費用無し" />
        <h3>追加費用なし</h3>
        <p>
          テンプレートは複製可能。
          追加費用不要ですべてのクライアント様に活用が可能。
        </p>
      </div>

      <div class="lead__feature3">
        <img src="/assets/img/point.svg" alt="無料で継続利用" />
        <h3>無料で継続利用</h3>
        <p>Looker Studioは無料で使用可能。</p>
      </div>
    </div>
  </div>
</section>

<section class="section__bg_lgreen_bottom">
  <div class="content__inner">
    <p class="section__title_en">High Quality Report Template</p>
    <h2 class="section__title">現場で使われている、実務仕様</h2>
    <div class="lead__text">
      <p>
        本テンプレートは、ウェブ解析士が実際のクライアントワークで使用しているレポート構成をもとに設計。<br
        />
        流入分析からコンバージョンまで、改善提案につながるストーリーで構成されています。<br
        />
        “数字を並べるだけ”ではない、 実務レベルレポートです。<br>
        PDF提出用テンプレートとリンク共有・管理用テンプレートの2種類をそれぞれご用意しております。
      </p>
    </div>
    <div class="image-l">
      <img src="/assets/img/pc-image.png" alt="レポート自動化画面" />
    </div>
  </div>
</section>

<section class="section__bg_w voices">
  <div class="content__inner">
    <p class="section__title_en">Customer Voices</p>
    <h2 class="section__title">お客様の声</h2>
    <div class="lead__text">
      <p>
毎月のレポート作成に追われていた方や、Looker Studioの活用に悩んでいた方から、さまざまなお声をいただいています。<br>
InsightBaseが、日々の業務負担を減らし、数字と向き合いやすくするきっかけになっています。
      </p>
    </div>

    <div class="voices__slider --pt50 js-voices-slider">
      <div class="voices__viewport">
        <div class="voices__track">
          {customerVoiceSlides.map((slide) => (
            <div class="voices__slide">
              <div class="voices__grid">
                {slide.map((voice) => (
                  <article class="voice-card">
                    <p class="voice-card__text">{voice.text}</p>
                    <div class="voice-card__footer">
                      <img
                        src={voice.image}
                        alt={voice.alt}
                      />
                      <div class="voice-card__meta">
                        <strong>{voice.role}</strong>
                        <span>{voice.meta}</span>
                      </div>
                    </div>
                  </article>
                ))}
              </div>
            </div>
          ))}
        </div>
      </div>

      <div class="voices__controls" aria-label="お客様の声の切り替え">
        <button
          type="button"
          class="voices__control is-active"
          data-slide="0"
          aria-label="1件目から3件目のお客様の声を表示"
          aria-pressed="true"></button>
        <button
          type="button"
          class="voices__control"
          data-slide="1"
          aria-label="4件目から6件目のお客様の声を表示"
          aria-pressed="false"></button>
      </div>
    </div>
  </div>
</section>

<Custom />
<Cta />

<Footer />
